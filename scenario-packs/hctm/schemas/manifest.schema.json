{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aese.iaos.local/schemas/manifest.schema.json",
  "title": "AESE scenario pack manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version","pack_key","pack_version","display_name","timezone","tenant_template","master_data","stories"],
  "properties": {
    "$schema": {"type":"string"},
    "schema_version": {"const":"1.0.0"},
    "pack_key": {"type":"string","pattern":"^[a-z][a-z0-9_-]*$"},
    "pack_version": {"type":"string","pattern":"^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "display_name": {"type":"string","minLength":1},
    "description": {"type":"string","minLength":1},
    "timezone": {"const":"Asia/Shanghai"},
    "tenant_template": {"type":"string","pattern":"^tenant-[a-z0-9-]+$"},
    "seed_version": {"type":"string","minLength":1},
    "master_data": {
      "type":"array","minItems":1,"uniqueItems":true,
      "items":{"$ref":"#/$defs/entry"}
    },
    "stories": {
      "type":"array","minItems":1,
      "items":{"$ref":"#/$defs/story"}
    }
  },
  "$defs": {
    "relativeJsonPath": {"type":"string","pattern":"^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+\\.json$"},
    "entry": {
      "type":"object","additionalProperties":false,"required":["key","path"],
      "properties": {
        "key":{"type":"string","pattern":"^[a-z][a-z0-9_-]*$"},
        "path":{"$ref":"#/$defs/relativeJsonPath"}
      }
    },
    "story": {
      "type":"object","additionalProperties":false,
      "required":["key","initial_state","events","expected_outcomes"],
      "properties": {
        "key":{"type":"string","pattern":"^[a-z][a-z0-9-]*$"},
        "scenario":{"type":"string","pattern":"^[a-z][a-z0-9_]*$"},
        "display_name":{"type":"string","minLength":1},
        "initial_state":{"$ref":"#/$defs/relativeJsonPath"},
        "events":{"$ref":"#/$defs/relativeJsonPath"},
        "expected_outcomes":{"$ref":"#/$defs/relativeJsonPath"}
      }
    }
  }
}
