{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aese.iaos.local/schemas/record-set.schema.json",
  "title": "AESE record set document",
  "oneOf": [
    {"$ref":"#/$defs/singleRecordSet"},
    {"$ref":"#/$defs/recordSetCollection"}
  ],
  "$defs": {
    "version": {"const":"1.0.0"},
    "record": {"type":"object","minProperties":1,"additionalProperties":true},
    "recordSetBody": {
      "type":"object",
      "additionalProperties":false,
      "required":["schema_version","entity","natural_key","records"],
      "properties": {
        "schema_version":{"$ref":"#/$defs/version"},
        "entity":{"type":"string","pattern":"^[a-z][a-z0-9_]*$"},
        "natural_key":{"type":"array","minItems":1,"uniqueItems":true,"items":{"type":"string","pattern":"^[a-z][a-z0-9_]*$"}},
        "records":{"type":"array","minItems":1,"items":{"$ref":"#/$defs/record"}}
      }
    },
    "singleRecordSet": {
      "type":"object",
      "additionalProperties":false,
      "required":["schema_version","entity","natural_key","records"],
      "properties": {
        "$schema":{"type":"string"},
        "schema_version":{"$ref":"#/$defs/version"},
        "entity":{"type":"string","pattern":"^[a-z][a-z0-9_]*$"},
        "natural_key":{"type":"array","minItems":1,"uniqueItems":true,"items":{"type":"string","pattern":"^[a-z][a-z0-9_]*$"}},
        "records":{"type":"array","minItems":1,"items":{"$ref":"#/$defs/record"}}
      }
    },
    "recordSetCollection": {
      "type":"object","additionalProperties":false,"required":["schema_version","record_sets"],
      "properties": {
        "$schema":{"type":"string"},
        "schema_version":{"$ref":"#/$defs/version"},
        "story_key":{"type":"string","pattern":"^[a-z][a-z0-9-]*$"},
        "record_sets":{"type":"array","minItems":1,"items":{"$ref":"#/$defs/recordSetBody"}}
      }
    }
  }
}
