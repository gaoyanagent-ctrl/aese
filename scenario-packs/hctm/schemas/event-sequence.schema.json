{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aese.iaos.local/schemas/event-sequence.schema.json",
  "title": "AESE ordered event sequence",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version","story_key","correlation_id","events"],
  "properties": {
    "$schema":{"type":"string"},
    "schema_version":{"const":"1.0.0"},
    "story_key":{"type":"string","pattern":"^[a-z][a-z0-9-]*$"},
    "scenario":{"type":"string","pattern":"^[a-z][a-z0-9_]*$"},
    "correlation_id":{"type":"string","minLength":1},
    "events":{"type":"array","minItems":1,"items":{"$ref":"#/$defs/event"}}
  },
  "$defs": {
    "event": {
      "type":"object","additionalProperties":false,
      "required":["sequence","event_id","tenant_id","event_type","source","timestamp","payload","metadata"],
      "properties": {
        "sequence":{"type":"integer","minimum":1},
        "event_id":{"type":"string","pattern":"^evt-[A-Za-z0-9-]+$"},
        "tenant_id":{"type":"string","pattern":"^tenant-[a-z0-9-]+$"},
        "event_type":{"type":"string","pattern":"^(o2d|proc|qms|eam|whs)\\.[a-z0-9_]+\\.[a-z0-9_]+$"},
        "subject":{"type":"string","pattern":"^iaos\\.[a-zA-Z0-9_-]+\\.[a-z0-9_.]+$"},
        "source":{"type":"string","minLength":1},
        "timestamp":{"type":"string","format":"date-time"},
        "correlation_id":{"type":"string","minLength":1},
        "causation_id":{"type":"string","pattern":"^evt-[A-Za-z0-9-]+$"},
        "idempotency_key":{"type":"string","minLength":1},
        "aggregate_type":{"type":"string","minLength":1},
        "aggregate_id":{"type":"string","minLength":1},
        "concurrent_group":{"type":"string","minLength":1},
        "payload":{"type":"object","minProperties":1,"additionalProperties":true},
        "metadata":{"$ref":"#/$defs/metadata"}
      }
    },
    "metadata": {
      "type":"object","additionalProperties":false,
      "required":["correlation_id","scenario","business_object_type","business_object_id","idempotency_key"],
      "properties": {
        "correlation_id":{"type":"string","minLength":1},
        "causation_id":{"type":"string","pattern":"^evt-[A-Za-z0-9-]+$"},
        "scenario":{"type":"string","pattern":"^[a-z][a-z0-9_]*$"},
        "plant_code":{"type":"string","pattern":"^PLT-[A-Z0-9-]+$"},
        "business_object_type":{"type":"string","pattern":"^[a-z][a-z0-9_]*$"},
        "business_object_id":{"type":"string","minLength":1},
        "idempotency_key":{"type":"string","minLength":1}
      }
    }
  }
}
