{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aese.local/world/v1/common.schema.json",
  "$defs": {
    "id": {"type":"string","minLength":1,"maxLength":200},
    "rfc3339": {"type":"string","format":"date-time"},
    "hash": {"type":"string","pattern":"^sha256:[0-9a-f]{64}$"},
    "decimal": {"type":"string","pattern":"^-?(0|[1-9][0-9]*)(\\.[0-9]+)?$"},
    "stable_ref": {"type":"object","additionalProperties":false,"required":["namespace","type","code"],"properties":{"namespace":{"$ref":"#/$defs/id"},"type":{"$ref":"#/$defs/id"},"code":{"$ref":"#/$defs/id"}}},
    "producer": {"type":"object","additionalProperties":false,"required":["system","component","version"],"properties":{"system":{"$ref":"#/$defs/id"},"component":{"$ref":"#/$defs/id"},"version":{"$ref":"#/$defs/id"}}}
  }
}
